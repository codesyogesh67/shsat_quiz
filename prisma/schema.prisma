generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  directUrl    = env("DIRECT_URL")
  relationMode = "foreignKeys"
}

enum PlanType {
  FREE
  TRIAL
  PREMIUM
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

model User {
  id             String   @id @default(cuid())
  email          String?  @unique
  name           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  externalAuthId String   @unique
  imageUrl       String?
  role           Role     @default(USER)

  planType         PlanType  @default(TRIAL)
  trialStartedAt   DateTime?
  trialEndsAt      DateTime?
  premiumStartedAt DateTime?
  premiumEndsAt    DateTime?

  stripeCustomerId     String?       @unique
  stripeSubscriptionId String?       @unique
  stripePriceId        String?
  subscriptionStatus   String?
  cancelAtPeriodEnd    Boolean       @default(false)
  billingCycle         BillingCycle?

  Attempt  Attempt[]
  sessions Session[] @relation("UserSessions")

  preferences UserPreferences?
}

model Question {
  id          String       @id @default(cuid())
  externalId  String?
  examKey     String?
  index       Int
  category    String?
  type        QuestionType @default(MULTIPLE_CHOICE)
  stem        String
  answer      String
  choices     Json?
  media       Json?
  explanation String?
  tags        String[]
  difficulty  Int?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  examId      String?
  attempts    Attempt[]
  exam        Exam?        @relation(fields: [examId], references: [id])

  @@index([examKey, index])
  @@index([examKey, externalId])
}

model Exam {
  id        String     @id @default(cuid())
  key       String     @unique
  year      Int?
  form      String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  questions Question[]
  sessions  Session[]
}

model Attempt {
  id              String    @id @default(cuid())
  questionId      String
  userId          String?
  sessionId       String
  givenAnswer     String?
  isCorrect       Boolean?
  createdAt       DateTime  @default(now())
  firstAnsweredAt DateTime?
  flagged         Boolean   @default(false)
  timeSpentSec    Int       @default(0)
  updatedAt       DateTime  @updatedAt
  question        Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  session         Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user            User?     @relation(fields: [userId], references: [id])

  @@unique([sessionId, questionId])
  @@index([questionId])
  @@index([userId])
  @@index([sessionId])
}

model Session {
  id                     String    @id @default(cuid())
  userId                 String?
  examId                 String?
  examKey                String?
  label                  String?
  mode                   String
  startedAt              DateTime  @default(now())
  submittedAt            DateTime?
  scoreCorrect           Int       @default(0)
  scoreTotal             Int       @default(0)
  minutes                Int?
  flagsCount             Int       @default(0)
  progressCount          Int       @default(0)
  questionIds            String[]
  serverSecondsRemaining Int?
  attempts               Attempt[]
  exam                   Exam?     @relation(fields: [examId], references: [id])
  user                   User?     @relation("UserSessions", fields: [userId], references: [id])

  @@index([userId])
  @@index([examKey])
}

enum Role {
  USER
  ADMIN
}

enum QuestionType {
  MULTIPLE_CHOICE
  FREE_RESPONSE
}

model UserPreferences {
  id                 String    @id @default(cuid())
  userId             String    @unique
  dailyStudyGoal     Int       @default(30)
  studyFocus         String    @default("weak_areas")
  targetExamDate     DateTime?
  parentSummaryEmail Boolean   @default(false)

  parentEmail  String?
  billingEmail String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
